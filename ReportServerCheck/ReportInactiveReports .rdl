<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Author>Uwe Janke - dtcSoftware</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ds_ReportServer">
      <DataSourceReference>ds_ReportServer</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>6ed802f2-f0d1-493d-acda-249dc1337a36</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="inactiveReports">
      <Query>
        <DataSourceName>ds_ReportServer</DataSourceName>
        <CommandText>Set transaction isolation level read uncommitted 

select		c.name,
		c.path,
		l.lastRunDate
from		catalog c
		left join (
			select		reportID,
					max(timeStart) as lastRunDate
			from		executionLog
			group by	reportID
		) l on c.itemID = l.reportID
		left join (
			select		distinct reportID
			from		executionLog
			where		timeStart &gt;= dateAdd(mm,-6,getDate())
		) e on c.itemID = e.reportID
where		e.reportID is null
		and c.type = 2 --Report
order by	                l.lastRunDate desc, 
		c.name</CommandText>
      </Query>
      <Fields>
        <Field Name="name">
          <DataField>name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="path">
          <DataField>path</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="lastRunDate">
          <DataField>lastRunDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
