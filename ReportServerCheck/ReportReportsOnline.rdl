  <DataSets>
    <DataSet Name="RollingUsage">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Set transaction isolation level read uncommitted 

select		myDates.runDate as runDate,
		coalesce(x.[Successful Hit],0) as [Successful Hit],
		coalesce(x.[Unsuccessful Hit],0) as [Unsuccessful Hit]

from		(
			select		replace(left(convert(varchar(20),getDate(),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-1,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-2,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-3,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-4,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-5,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-6,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-7,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-8,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-9,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-10,getDate()),102),7),'.','-') as runDate
			union
			select		replace(left(convert(varchar(20),dateAdd(mm,-11,getDate()),102),7),'.','-') as runDate
		) myDates 
		left join (
			select		replace(left(convert(varchar(20),e.timeStart,102),7),'.','-') as runDate,
			sum(case when [status]='rsSuccess' then 1 else 0 end) as [Successful Hit],
			sum(case when [status]='rsSuccess' then 0 else 1 end) as [Unsuccessful Hit]
			from		executionLog e
			where		requestType = 0
					and TimeStart &gt;= dateAdd(mm,-12,getDate())
			group by	replace(left(convert(varchar(20),e.timeStart,102),7),'.','-')
		) x on myDates.runDate = x.runDate
order by                 myDates.runDate</CommandText>
      </Query>
      <Fields>
        <Field Name="runDate">
          <DataField>runDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Successful_Hit">
          <DataField>Successful Hit</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Unsuccessful_Hit">
          <DataField>Unsuccessful Hit</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
