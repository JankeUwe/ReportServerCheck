<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ds_ReportServer">
      <DataSourceReference>ds_ReportServer</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1e447039-95ec-4ef8-ba4a-6b7d77397916</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>ds_ReportServer</DataSourceName>
        <CommandText>SET                TRANSACTION isolation level READ uncommitted
                             SELECT        TOP 20 c.itemID, c.name, c.path, count(c.itemID) AS totalEntries
                              FROM            executionLog e INNER JOIN
                                                       catalog c ON e.reportID = c.itemID
                              WHERE        e.requestType = 0 AND e.timeStart &gt;= dateAdd(mm, - 12, getDate())
                              GROUP BY c.itemID, c.name, c.path
                              ORDER BY totalEntries DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="itemID">
          <DataField>itemID</DataField>
          <rd:TypeName>System.Guid</rd:TypeName>
        </Field>
        <Field Name="name">
          <DataField>name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="path">
          <DataField>path</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="totalEntries">
          <DataField>totalEntries</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
