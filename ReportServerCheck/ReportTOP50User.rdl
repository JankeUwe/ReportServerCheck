  <Author>Uwe Janke - dtcSoftware</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>ds_ReportServer</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>a16fcbea-95d6-470c-a358-4e1c56ff82d9</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="top10Users">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Set transaction isolation level read uncommitted 

select		top 50
		userName,
		count(*) as executionCount
from		executionLog
where		requestType = 0 and timeStart &gt;= dateAdd(mm,-6,getDate())
group by	                userName
order by	                executionCount desc</CommandText>
      </Query>
      <Fields>
        <Field Name="userName">
          <DataField>userName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="executionCount">
          <DataField>executionCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
