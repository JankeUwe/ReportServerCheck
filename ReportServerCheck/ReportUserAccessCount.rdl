  <Author>Uwe Janke - dtcSoftware</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>ds_ReportServer</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>92679b46-fcf7-4d27-aa47-ad3785c3c809</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="UserCount">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SET                TRANSACTION isolation level READ uncommitted
                             SELECT        myDates.runDate AS runDate, COALESCE (x.userCount, 0) AS userCount
                              FROM            (SELECT        replace(LEFT(CONVERT(varchar(20), getDate(), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 1, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 2, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 3, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 4, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 5, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 6, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 7, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 8, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 9, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 10, getDate()), 102), 7), '.', '-') AS runDate
                                                        UNION
                                                        SELECT        replace(LEFT(CONVERT(varchar(20), dateAdd(mm, - 11, getDate()), 102), 7), '.', '-') AS runDate) myDates LEFT JOIN
                                                           (SELECT        count(DISTINCT userName) AS userCount, replace(LEFT(CONVERT(varchar(20), timeStart, 102), 7), '.', '-') AS loginMonth
                                                             FROM            executionLog
                                                             WHERE        requestType = 0 AND timeStart &gt;= dateAdd(mm, - 12, CONVERT(dateTime, LEFT(CONVERT(varchar(20), getDate(), 102), 8) + '01'))
                                                             GROUP BY replace(LEFT(CONVERT(varchar(20), timeStart, 102), 7), '.', '-')) x ON myDates.runDate = x.loginMonth
                              ORDER BY myDates.runDate</CommandText>
      </Query>
      <Fields>
        <Field Name="runDate">
          <DataField>runDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="userCount">
          <DataField>userCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
